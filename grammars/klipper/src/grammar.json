{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "klipper",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "section"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          }
        ]
      }
    },
    "section": {
      "type": "PREC_DYNAMIC",
      "value": -1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "FIELD",
            "name": "name",
            "content": {
              "type": "SYMBOL",
              "name": "section_name"
            }
          },
          {
            "type": "STRING",
            "value": "]"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "section_item"
            }
          }
        ]
      }
    },
    "section_name": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9_ \\-\\.\\/]+"
    },
    "section_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "setting"
        },
        {
          "type": "SYMBOL",
          "name": "line_comment"
        },
        {
          "type": "SYMBOL",
          "name": "save_config_line"
        }
      ]
    },
    "setting": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "setting_key"
          }
        },
        {
          "type": "FIELD",
          "name": "separator",
          "content": {
            "type": "SYMBOL",
            "name": "setting_separator"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "value_text"
          }
        }
      ]
    },
    "setting_key": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_.\\-]*"
    },
    "setting_separator": {
      "type": "PATTERN",
      "value": "[=:]"
    },
    "value_text": {
      "type": "PATTERN",
      "value": "[^\\n\\r]+"
    },
    "comment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "save_config_line"
        },
        {
          "type": "SYMBOL",
          "name": "line_comment"
        }
      ]
    },
    "line_comment": {
      "type": "PATTERN",
      "value": "[#;][^\\n]*"
    },
    "save_config_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "#\\*#[^\\n]*"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}